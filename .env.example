# NexoAccManager Landing - Environment Variables for Vercel

# Backend API URL (the deployed Railway instance)
# Set this in Vercel dashboard: Settings → Environment Variables
NEXT_PUBLIC_BACKEND_URL="https://your-railway-backend.railway.app"

# Stripe (optional - mock mode works without it)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# App URL (used for redirects in auth flows)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"